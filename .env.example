# Supabase connection — paste YOUR own project's values here.
# Find both in your Supabase dashboard: Project Settings -> API.
# These two values are safe to use in a frontend app. NEVER put the
# "service_role" secret key in here.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=paste-your-anon-public-key-here
